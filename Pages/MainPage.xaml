<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="APP_GoiXetheoGPS.Pages.MainPage"
             Title="Trang chủ"
             BackgroundColor="{AppThemeBinding Light=#F5F7FA, Dark={StaticResource DarkBackground}}">

	<ScrollView>
		<VerticalStackLayout Padding="20,16" Spacing="20">

			<!-- Header -->
			<VerticalStackLayout Spacing="6">
				<Label Text="Dashboard"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#111827, Dark=White}" />

				<Label Text="Thông tin cơ sở dữ liệu phân tán"
                       FontSize="14"
                       TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
			</VerticalStackLayout>

			<!-- Refresh Button -->
			<Button x:Name="RefreshDbButton"
                    Text="🔄 Làm mới dữ liệu"
                    WidthRequest="220"
                    HorizontalOptions="Center"
                    CornerRadius="12"
                    Padding="16,12"
                    FontSize="14"
                    FontAttributes="Bold"
                    Clicked="RefreshDbButton_OnClicked"
                    BackgroundColor="#2D7DFF"
                    TextColor="White" />

			<!-- Loading -->
			<VerticalStackLayout HorizontalOptions="Center" Spacing="8">
				<ActivityIndicator x:Name="LoadingIndicator"
                                   IsRunning="False"
                                   IsVisible="False" />
				<Label x:Name="LoadingLabel"
                       Text="Đang tải dữ liệu..."
                       IsVisible="False"
                       FontSize="14"
                       TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
			</VerticalStackLayout>

			<!-- Database Cards -->
			<CollectionView x:Name="DatabaseStatsCollection"
                            SelectionMode="None">
				<CollectionView.ItemTemplate>
					<DataTemplate>
						<Border StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#404048}"
                                BackgroundColor="{Binding CardBackgroundColor}"
                                Padding="15"
                                Margin="0,0,0,10">

							<Border.StrokeShape>
								<RoundRectangle CornerRadius="14" />
							</Border.StrokeShape>

							<VerticalStackLayout Spacing="8">

								<Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="10">

									<Label Text="{Binding Icon}"
                                           FontSize="18"
                                           VerticalOptions="Center" />

									<Label Grid.Column="1"
                                           Text="{Binding DatabaseName}"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#111827, Dark=White}" />
								</Grid>

								<BoxView HeightRequest="1"
                                         Color="{AppThemeBinding Light=#E5E7EB, Dark=#404048}" />

								<Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="8">

									<Label Text="Bản ghi:"
                                           FontSize="13"
                                           TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />

									<Label Grid.Column="1"
                                           Text="{Binding RecordCountDisplay}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="{Binding AccentColor}" />
								</Grid>

								<Label Text="{Binding LastUpdatedDisplay}"
                                       FontSize="11"
                                       TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#6B7280}" />

							</VerticalStackLayout>
						</Border>
					</DataTemplate>
				</CollectionView.ItemTemplate>
			</CollectionView>

			<!-- System Info -->
			<Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#404048}"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A32}"
                    Padding="15">

				<Border.StrokeShape>
					<RoundRectangle CornerRadius="14" />
				</Border.StrokeShape>

				<VerticalStackLayout Spacing="8">
					<Label Text="ℹ️ Thông tin hệ thống"
                           FontSize="14"
                           FontAttributes="Bold" />

					<Label x:Name="LastUpdatedLabel"
                           Text="Chưa cập nhật"
                           FontSize="12" />

					<Label x:Name="TotalRecordsLabel"
                           Text="Tổng cộng: 0 bản ghi"
                           FontSize="12" />
				</VerticalStackLayout>
			</Border>

			<!-- Demo Section -->
			<Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#404048}"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A32}"
                    Padding="15">

				<Border.StrokeShape>
					<RoundRectangle CornerRadius="14" />
				</Border.StrokeShape>

				<VerticalStackLayout Spacing="12">

					<Label Text="🧪 Kiểm tra trạng thái DB"
                           FontSize="14"
                           FontAttributes="Bold" />

					<Grid ColumnDefinitions="*,*" ColumnSpacing="10">

						<!-- DB1 -->
						<VerticalStackLayout Spacing="6">
							<Label Text="DB1"
                                   FontSize="13"
                                   FontAttributes="Bold" />

							<BoxView x:Name="Db1StatusBox"
                                     HeightRequest="8"
                                     CornerRadius="4"
                                     Color="#10B981" />

							<Label x:Name="Db1StatusLabel"
                                   Text="🟢 Online"
                                   FontSize="12" />
						</VerticalStackLayout>

						<!-- DB2 -->
						<VerticalStackLayout Grid.Column="1"
                                             Spacing="6">
							<Label Text="DB2"
                                   FontSize="13"
                                   FontAttributes="Bold" />

							<BoxView x:Name="Db2StatusBox"
                                     HeightRequest="8"
                                     CornerRadius="4"
                                     Color="#EF4444" />

							<Label x:Name="Db2StatusLabel"
                                   Text="🔴 Offline"
                                   FontSize="12" />
						</VerticalStackLayout>

					</Grid>


					<Picker x:Name="DatabasePicker"
							Title="Chọn database cần kiểm tra"
							SelectedIndex="0">
						<Picker.Items>
							<x:String>DB1</x:String>
							<x:String>DB2</x:String>
						</Picker.Items>
					</Picker>

					<Button Text="Kết nối DB"
                            CornerRadius="10"
                            Padding="12,10"
                            FontSize="13"
                            FontAttributes="Bold"
                            Clicked="TestDatabaseButton_OnClicked"
                            BackgroundColor="#10B981"
                            TextColor="White" />

				</VerticalStackLayout>
			</Border>

		</VerticalStackLayout>
	</ScrollView>
</ContentPage>