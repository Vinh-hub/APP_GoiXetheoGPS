<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="APP_GoiXetheoGPS.Pages.MainPage"
             Title="Trang chủ"
             BackgroundColor="{AppThemeBinding Light=#F5F7FA, Dark={StaticResource DarkBackground}}">

	<ScrollView>
		<VerticalStackLayout Padding="20,16" Spacing="20">

			<!-- Header -->
			<VerticalStackLayout Spacing="6">
				<Label Text="Dashboard"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#111827, Dark=White}" />

				<Label Text="Thông tin cơ sở dữ liệu phân tán"
                       FontSize="14"
                       TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
			</VerticalStackLayout>

            <!-- Khu vực kết nối DB + điều hướng nhanh -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#404048}"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A32}"
                    Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="10">
                    <Label Text="🌍 Chọn khu vực kết nối"
                           FontSize="14"
                           FontAttributes="Bold" />

                    <Label x:Name="SelectedRegionLabel"
                           Text="Đang dùng: Theo GPS"
                           FontSize="12"
                           TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <Button Grid.Column="0"
                                Text="Hà Nội (North)"
                                CornerRadius="10"
                                FontSize="12"
                                Clicked="NorthRegionButton_OnClicked"
                                BackgroundColor="#1D4ED8"
                                TextColor="White" />

                        <Button Grid.Column="1"
                                Text="TP.HCM (South)"
                                CornerRadius="10"
                                FontSize="12"
                                Clicked="SouthRegionButton_OnClicked"
                                BackgroundColor="#0EA5E9"
                                TextColor="White" />

                        <Button Grid.Column="2"
                                Text="Theo GPS"
                                CornerRadius="10"
                                FontSize="12"
                                Clicked="UseGpsRegionButton_OnClicked"
                                BackgroundColor="#6B7280"
                                TextColor="White" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Grid.Column="0"
                                Text="🚕 Đặt chuyến"
                                CornerRadius="10"
                                FontAttributes="Bold"
                                Clicked="BookTripButton_OnClicked"
                                BackgroundColor="#10B981"
                                TextColor="White" />

                        <Button Grid.Column="1"
                                Text="📋 Xem lịch sử"
                                CornerRadius="10"
                                FontAttributes="Bold"
                                Clicked="ViewHistoryButton_OnClicked"
                                BackgroundColor="#7C3AED"
                                TextColor="White" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
		</VerticalStackLayout>
	</ScrollView>
</ContentPage>