<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="APP_GoiXetheoGPS.Pages.AuthPage"
             Title="Tài khoản"
             BackgroundColor="White">
    <ScrollView>
        <VerticalStackLayout Padding="16,14,16,24" Spacing="12">
            <Label Text="Tài khoản"
                   FontSize="36"
                   FontAttributes="Bold"
                   TextColor="#111827" />
            <Label Text="Quản lý đăng nhập, đăng ký và phiên của bạn."
                   FontSize="13"
                   TextColor="#6B7280" />

            <Border StrokeThickness="1"
                    Stroke="#DDE8E0"
                    BackgroundColor="White"
                    Padding="12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label Text="Phiên đăng nhập" FontAttributes="Bold" FontSize="15" />
                    <Label x:Name="JwtStatusLabel" Text="Chưa đăng nhập" FontSize="13" />
                    <Label x:Name="ExpiryStatusLabel"
                           Text="Hạn dùng: Chưa có"
                           FontSize="12"
                           TextColor="#6B7280" />
                    <Label x:Name="SessionStatusLabel"
                           Text="Chưa xác thực phiên"
                           FontSize="12"
                           TextColor="#6B7280" />
                    <Button x:Name="CheckSessionButton"
                            Text="Kiểm tra phiên"
                            Clicked="CheckSessionButton_OnClicked"
                            BackgroundColor="#EDF6FF"
                            TextColor="#1F4E8C"
                            CornerRadius="12" />
                    <Button x:Name="LogoutButton"
                            Text="Đăng xuất"
                            Clicked="LogoutButton_OnClicked"
                            BackgroundColor="#FFECEE"
                            TextColor="#C62828"
                            CornerRadius="12" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
