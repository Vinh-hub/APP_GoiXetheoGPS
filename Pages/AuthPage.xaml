<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="APP_GoiXetheoGPS.Pages.AuthPage"
             Title="Tài khoản"
             BackgroundColor="{AppThemeBinding Light=#F5F7FA, Dark={StaticResource DarkBackground}}">

    <ScrollView>
        <VerticalStackLayout Padding="20,16" Spacing="16">
            <Label Text="Đăng nhập / Đăng ký"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#111827, Dark=White}" />

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#404048}"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A32}"
                    Padding="14">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Trạng thái JWT" FontAttributes="Bold" />
                    <Label x:Name="JwtStatusLabel" Text="Chưa đăng nhập" />
                    <Label x:Name="SessionStatusLabel"
                           Text="Chưa xác thực phiên"
                           FontSize="12"
                           Opacity="0.8" />
                    <Button x:Name="CheckSessionButton"
                            Text="Kiểm tra phiên đăng nhập"
                            Clicked="CheckSessionButton_OnClicked"
                            CornerRadius="12" />
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#404048}"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A32}"
                    Padding="14">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Đăng nhập" FontAttributes="Bold" />
                    <Entry x:Name="LoginEmailEntry" Placeholder="Email" Keyboard="Email" />
                    <Entry x:Name="LoginPasswordEntry" Placeholder="Mật khẩu" IsPassword="True" />
                    <Button x:Name="LoginButton"
                            Text="Đăng nhập"
                            Clicked="LoginButton_OnClicked"
                            BackgroundColor="#2D7DFF"
                            TextColor="White"
                            CornerRadius="12" />
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#404048}"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A32}"
                    Padding="14">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Đăng ký" FontAttributes="Bold" />
                    <Entry x:Name="RegisterNameEntry" Placeholder="Họ tên" />
                    <Entry x:Name="RegisterPhoneEntry" Placeholder="Số điện thoại" Keyboard="Telephone" />
                    <Entry x:Name="RegisterEmailEntry" Placeholder="Email" Keyboard="Email" />
                    <Entry x:Name="RegisterPasswordEntry" Placeholder="Mật khẩu" IsPassword="True" />
                    <Button x:Name="RegisterButton"
                            Text="Đăng ký"
                            Clicked="RegisterButton_OnClicked"
                            BackgroundColor="#10B981"
                            TextColor="White"
                            CornerRadius="12" />
                </VerticalStackLayout>
            </Border>

            <Button x:Name="LogoutButton"
                    Text="Đăng xuất"
                    Clicked="LogoutButton_OnClicked"
                    CornerRadius="12" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
