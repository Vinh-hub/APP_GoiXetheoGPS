<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:f="clr-namespace:Fonts"
             x:Class="APP_GoiXetheoGPS.Pages.TripDetailPage"
             Title="Chi tiết chuyến"
             BackgroundColor="{AppThemeBinding Light=#F5F7FA, Dark={StaticResource DarkBackground}}">

    <ScrollView Padding="20,12">
        <VerticalStackLayout Spacing="18">

            <Border Padding="18"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFFFF, Dark=#FF222228}"
                    Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#33333A}"
                    StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="6">
                    <Label Style="{StaticResource Caption1}"
                           Text="Lộ trình"
                           TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
                    <Label x:Name="RouteLabel"
                           Style="{StaticResource Body1Strong}"
                           TextColor="{AppThemeBinding Light=#111827, Dark={StaticResource LightOnDarkBackground}}" />
                    <Label x:Name="WhenLabel"
                           Style="{StaticResource Caption1}"
                           TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
                </VerticalStackLayout>
            </Border>

            <Label Style="{StaticResource Title3}"
                   Text="Chi tiết"
                   TextColor="{AppThemeBinding Light=#111827, Dark={StaticResource LightOnDarkBackground}}" />

            <Border Padding="18"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFFFF, Dark=#FF222228}"
                    Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#33333A}"
                    StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="20">

                    <VerticalStackLayout Spacing="10">
                        <Label Style="{StaticResource Caption1Strong}"
                               Text="Tài xế"
                               TextColor="{StaticResource Primary}" />
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                            <Border HeightRequest="56"
                                    StrokeThickness="0"
                                    WidthRequest="56">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="28" />
                                </Border.StrokeShape>
                                <Border.Background>
                                    <SolidColorBrush Color="{StaticResource Secondary}" />
                                </Border.Background>
                                <Image HeightRequest="30"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       WidthRequest="30">
                                    <Image.Source>
                                        <FontImageSource FontFamily="{x:Static f:FluentUI.FontFamily}"
                                                         Glyph="{x:Static f:FluentUI.person_24_regular}"
                                                         Color="{StaticResource Primary}"
                                                         Size="30" />
                                    </Image.Source>
                                </Image>
                            </Border>
                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2"
                                                 VerticalOptions="Center">
                                <Label x:Name="DriverNameLabel"
                                       Style="{StaticResource Body1Strong}"
                                       TextColor="{AppThemeBinding Light=#111827, Dark={StaticResource LightOnDarkBackground}}" />
                                <Label x:Name="VehicleLabel"
                                       Style="{StaticResource Caption1}"
                                       TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light=#E5E7EB, Dark=#2A2A32}" />

                    <VerticalStackLayout Spacing="6">
                        <Label Style="{StaticResource Caption1Strong}"
                               Text="Giá"
                               TextColor="{StaticResource Primary}" />
                        <Label x:Name="PriceLabel"
                               Style="{StaticResource Body1Strong}"
                               TextColor="{AppThemeBinding Light=#111827, Dark={StaticResource LightOnDarkBackground}}" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light=#E5E7EB, Dark=#2A2A32}" />

                    <VerticalStackLayout Spacing="8">
                        <Label Style="{StaticResource Caption1Strong}"
                               Text="Trạng thái"
                               TextColor="{StaticResource Primary}" />
                        <Border x:Name="StatusBadge"
                                Padding="12,6"
                                HorizontalOptions="Start"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20" />
                            </Border.StrokeShape>
                            <Label x:Name="StatusLabel"
                                   Style="{StaticResource Caption1Strong}"
                                   TextColor="#0B1B33" />
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
