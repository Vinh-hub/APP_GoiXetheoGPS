<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="APP_GoiXetheoGPS.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:sf="clr-namespace:Syncfusion.Maui.Toolkit.SegmentedControl;assembly=Syncfusion.Maui.Toolkit"
    xmlns:pages="clr-namespace:APP_GoiXetheoGPS.Pages"
    Shell.FlyoutBehavior="Flyout"
    Title="APP_GoiXetheoGPS">

    <ShellContent
        x:Name="AuthWelcomeShellContent"
        Shell.FlyoutItemIsVisible="False"
        ContentTemplate="{DataTemplate pages:AuthWelcomePage}"
        Route="auth-welcome" />

    <ShellContent
        Shell.FlyoutItemIsVisible="False"
        ContentTemplate="{DataTemplate pages:LoginPage}"
        Route="auth-login" />

    <ShellContent
        Shell.FlyoutItemIsVisible="False"
        ContentTemplate="{DataTemplate pages:RegisterPage}"
        Route="auth-register" />

    <ShellContent
        Title="Trang chủ"
        Icon="{StaticResource IconDashboard}"
        ContentTemplate="{DataTemplate pages:MainPage}"
        Route="home" />

    <ShellContent
        Title="Bản đồ"
        Icon="{StaticResource IconHomeMap}"
        ContentTemplate="{DataTemplate pages:HomeMapPage}"
        Route="map" />

    <ShellContent
        Title="Theo dõi chuyến"
        Icon="{StaticResource IconTripTrack}"
        ContentTemplate="{DataTemplate pages:TripTrackingPage}"
        Route="trips" />

    <ShellContent
        x:Name="AuthShellContent"
        Title="Tài khoản"
        Icon="{StaticResource IconDashboard}"
        ContentTemplate="{DataTemplate pages:AuthPage}"
        Route="auth" />

    <Shell.FlyoutFooter>
        <Grid Padding="15">
            <sf:SfSegmentedControl x:Name="ThemeSegmentedControl" 
                VerticalOptions="Center" HorizontalOptions="Center" SelectionChanged="SfSegmentedControl_SelectionChanged"
                SegmentWidth="40" SegmentHeight="40">
                <sf:SfSegmentedControl.ItemsSource>
                    <x:Array Type="{x:Type sf:SfSegmentItem}">
                        <sf:SfSegmentItem ImageSource="{StaticResource IconLight}" SemanticProperties.Description="Light mode"/>
                        <sf:SfSegmentItem ImageSource="{StaticResource IconDark}" SemanticProperties.Description="Dark mode"/>
                    </x:Array>
                </sf:SfSegmentedControl.ItemsSource>
            </sf:SfSegmentedControl>
        </Grid>
    </Shell.FlyoutFooter>

</Shell>
