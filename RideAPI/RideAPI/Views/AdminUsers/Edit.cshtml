@model RideAPI.Models.ViewModels.AdminUserUpsertViewModel
@{
    ViewData["Title"] = "Sửa user";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        body { font-family: Arial, Helvetica, sans-serif; background: #f4f6fb; color: #111827; }
        .box { max-width: 640px; margin: 24px auto; background:#fff; padding:20px; border-radius:12px; }
        .row { margin-bottom:10px; }
        label { display:block; font-size:14px; margin-bottom:4px; }
        input, select { width:100%; padding:9px; border:1px solid #d1d5db; border-radius:8px; box-sizing:border-box; }
        .err { color:#dc2626; font-size:13px; }
        .actions { margin-top:14px; display:flex; gap:8px; }
        button, a { border:0; text-decoration:none; color:#fff; padding:8px 12px; border-radius:8px; cursor:pointer; }
        .save { background:#2563eb; }
        .back { background:#6b7280; }
    </style>
</head>
<body>
<div class="box">
    <h1 style="margin-top:0;">Sửa user #@Model.UserId</h1>
    <form asp-action="Edit" asp-controller="AdminUsers" asp-route-id="@Model.UserId" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="UserId" />
        <input type="hidden" asp-for="RegionId" />

        <div asp-validation-summary="ModelOnly" class="err"></div>

        <div class="row"><label asp-for="Email"></label><input asp-for="Email" /><span asp-validation-for="Email" class="err"></span></div>
        <div class="row"><label asp-for="Password">Password mới (để trống nếu giữ nguyên)</label><input asp-for="Password" type="password" /><span asp-validation-for="Password" class="err"></span></div>
        <div class="row">
            <label asp-for="Role"></label>
            <select asp-for="Role">
                <option>Customer</option>
                <option>Driver</option>
                <option>Admin</option>
            </select>
            <span asp-validation-for="Role" class="err"></span>
        </div>
        <div class="row"><label asp-for="CustomerId"></label><input asp-for="CustomerId" type="number" /><span asp-validation-for="CustomerId" class="err"></span></div>
        <div class="row"><label asp-for="DriverId"></label><input asp-for="DriverId" type="number" /><span asp-validation-for="DriverId" class="err"></span></div>
        <div class="row"><label asp-for="Name"></label><input asp-for="Name" /></div>
        <div class="row"><label asp-for="Phone"></label><input asp-for="Phone" /></div>
        <div class="row"><label><input asp-for="IsActive" type="checkbox" /> Kích hoạt</label></div>

        <div class="actions">
            <button class="save" type="submit">Lưu</button>
            <a class="back" href="/admin/users">Quay lại</a>
        </div>
    </form>
</div>
</body>
</html>
