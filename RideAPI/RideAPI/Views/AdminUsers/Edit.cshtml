@model RideAPI.Models.ViewModels.AdminUserUpsertViewModel
@{
    ViewData["Title"] = "Sửa người dùng";
    ViewData["Nav"] = "users";
}

<div class="admin-form-shell">
    <div class="panel admin-form-card">
        <div class="admin-form-header">
            <div>
                <h1 class="admin-form-title">Sửa người dùng #@Model.UserId</h1>
                <div class="admin-form-subtitle">
                    Cập nhật thông tin tài khoản, vai trò và vùng dữ liệu. Bạn có thể thay đổi tọa độ hoặc tỉnh/thành để chuyển vùng quản lý khi cần.
                </div>
            </div>
            <div class="admin-form-badge">Chỉnh sửa</div>
        </div>

        <form asp-action="Edit" asp-controller="AdminUsers" asp-route-id="@Model.UserId" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="RegionId" />

            <div asp-validation-summary="ModelOnly" class="error"></div>

            <div class="admin-form-sections">
                <section class="admin-form-section">
                    <h2 class="admin-form-section-title">Thông tin đăng nhập</h2>
                    <p class="admin-form-section-subtitle">Để trống mật khẩu nếu bạn muốn giữ nguyên mật khẩu hiện tại.</p>
                    <div class="admin-form-grid">
                        <div class="admin-form-field">
                            <label asp-for="Email" class="admin-form-label"></label>
                            <input asp-for="Email" class="admin-form-input" />
                            <span asp-validation-for="Email" class="error"></span>
                        </div>
                        <div class="admin-form-field">
                            <label asp-for="Password" class="admin-form-label">Mật khẩu mới</label>
                            <input asp-for="Password" type="password" class="admin-form-input" placeholder="Để trống nếu giữ nguyên" />
                            <span asp-validation-for="Password" class="error"></span>
                        </div>
                        <div class="admin-form-field">
                            <label asp-for="Role" class="admin-form-label"></label>
                            <select asp-for="Role" class="admin-form-select">
                                <option>Customer</option>
                                <option>Driver</option>
                                <option>Admin</option>
                            </select>
                            <span asp-validation-for="Role" class="error"></span>
                        </div>
                        <div class="admin-form-field">
                            <label class="admin-form-label">&nbsp;</label>
                            <label class="admin-form-check">
                                <input asp-for="IsActive" type="checkbox" />
                                Tài khoản đang hoạt động
                            </label>
                        </div>
                    </div>
                </section>

                <section class="admin-form-section">
                    <h2 class="admin-form-section-title">Thông tin hồ sơ</h2>
                    <p class="admin-form-section-subtitle">Cập nhật thông tin hiển thị và liên kết ID chuyên biệt khi cần.</p>
                    <div class="admin-form-grid">
                        <div class="admin-form-field">
                            <label asp-for="Name" class="admin-form-label"></label>
                            <input asp-for="Name" class="admin-form-input" />
                        </div>
                        <div class="admin-form-field">
                            <label asp-for="Phone" class="admin-form-label"></label>
                            <input asp-for="Phone" class="admin-form-input" />
                        </div>
                        <div class="admin-form-field">
                            <label asp-for="CustomerId" class="admin-form-label"></label>
                            <input asp-for="CustomerId" type="number" class="admin-form-input" />
                            <span asp-validation-for="CustomerId" class="error"></span>
                        </div>
                        <div class="admin-form-field">
                            <label asp-for="DriverId" class="admin-form-label"></label>
                            <input asp-for="DriverId" type="number" class="admin-form-input" />
                            <span asp-validation-for="DriverId" class="error"></span>
                        </div>
                    </div>
                </section>

                <section class="admin-form-section">
                    <h2 class="admin-form-section-title">Phân vùng dữ liệu</h2>
                    <p class="admin-form-section-subtitle">Nhập lại vị trí nếu bạn muốn chuyển người dùng sang vùng dữ liệu khác.</p>
                    <div class="admin-form-grid">
                        <div class="admin-form-field full">
                            <label class="admin-form-label">Tỉnh/Thành (tuỳ chọn)</label>
                            <input asp-for="Province" class="admin-form-input" placeholder="VD: Hà Nội, TP. Hồ Chí Minh" />
                            <span asp-validation-for="Province" class="error"></span>
                        </div>
                        <div class="admin-form-field">
                            <label class="admin-form-label">Latitude (tuỳ chọn)</label>
                            <input asp-for="Latitude" type="number" step="0.000001" class="admin-form-input" placeholder="VD: 21.0285" />
                            <span asp-validation-for="Latitude" class="error"></span>
                        </div>
                        <div class="admin-form-field">
                            <label class="admin-form-label">Longitude (tham khảo)</label>
                            <input asp-for="Longitude" type="number" step="0.000001" class="admin-form-input" placeholder="VD: 105.8542" />
                            <span asp-validation-for="Longitude" class="error"></span>
                        </div>
                    </div>
                </section>
            </div>

            <div class="form-actions">
                <button class="btn btn-add" type="submit">Lưu thay đổi</button>
                <a class="btn btn-back" href="/admin/users">Quay lại danh sách</a>
            </div>
        </form>
    </div>
</div>
