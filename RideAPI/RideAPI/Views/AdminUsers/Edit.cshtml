@model RideAPI.Models.ViewModels.AdminUserUpsertViewModel
@{
    ViewData["Title"] = "Sửa người dùng";
    ViewData["Nav"] = "users";
}

<div class="container">
    <div class="form-box">
        <h1 style="margin-top:0;">Sửa người dùng #@Model.UserId</h1>
        <form asp-action="Edit" asp-controller="AdminUsers" asp-route-id="@Model.UserId" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="RegionId" />
            <div class="hint" style="margin-top:10px;">Bạn có thể đổi vùng bằng cách nhập tọa độ/tỉnh rồi lưu.</div>

            <div asp-validation-summary="ModelOnly" class="error"></div>

            <div class="form-row"><label asp-for="Email"></label><input asp-for="Email" /><span asp-validation-for="Email" class="error"></span></div>
            <div class="form-row"><label asp-for="Password">Mật khẩu mới (để trống nếu giữ nguyên)</label><input asp-for="Password" type="password" /><span asp-validation-for="Password" class="error"></span></div>
            <div class="form-row">
                <label asp-for="Role"></label>
                <select asp-for="Role">
                    <option>Customer</option>
                    <option>Driver</option>
                    <option>Admin</option>
                </select>
                <span asp-validation-for="Role" class="error"></span>
            </div>
            <div class="form-row"><label asp-for="CustomerId"></label><input asp-for="CustomerId" type="number" /><span asp-validation-for="CustomerId" class="error"></span></div>
            <div class="form-row"><label asp-for="DriverId"></label><input asp-for="DriverId" type="number" /><span asp-validation-for="DriverId" class="error"></span></div>
            <div class="form-row"><label asp-for="Name"></label><input asp-for="Name" /></div>
            <div class="form-row"><label asp-for="Phone"></label><input asp-for="Phone" /></div>
            <div class="form-row"><label>Tỉnh/Thành (tuỳ chọn)</label><input asp-for="Province" placeholder="VD: Ha Noi, Ho Chi Minh" /><span asp-validation-for="Province" class="error"></span></div>
            <div class="form-row"><label>Latitude (tuỳ chọn)</label><input asp-for="Latitude" type="number" step="0.000001" placeholder="VD: 21.0285" /><span asp-validation-for="Latitude" class="error"></span></div>
            <div class="form-row"><label>Longitude (tham khảo)</label><input asp-for="Longitude" type="number" step="0.000001" placeholder="VD: 105.8542" /><span asp-validation-for="Longitude" class="error"></span></div>
            <div class="form-row"><label><input asp-for="IsActive" type="checkbox" /> Kích hoạt</label></div>

            <div class="form-actions">
                <button class="btn btn-add" type="submit">Lưu</button>
                <a class="btn btn-back" href="/admin/users">Quay lại</a>
            </div>
        </form>
    </div>
</div>
