@model List<RideAPI.Models.ViewModels.AdminUserListItemViewModel>
@{
    ViewData["Title"] = "Quản lý người dùng";
    ViewData["Nav"] = "users";
}

<div class="panel search-bar">
    <h1 class="panel-title">Quản lý người dùng</h1>
    <form method="get" action="/admin/users" class="search-grid">
        <div>
            <div class="field-label">Tìm kiếm</div>
            <input class="field-input" type="text" name="keyword" value="@ViewBag.Keyword" placeholder="🔍  Tìm theo tên, email..." />
        </div>
        <div>
            <div class="field-label">Vai trò</div>
            <select class="field-select" name="role">
                <option value="" selected="@(string.IsNullOrWhiteSpace((string?)ViewBag.Role))">Tất cả</option>
                <option value="Admin" selected="@((string?)ViewBag.Role == "Admin")">Admin</option>
                <option value="Customer" selected="@((string?)ViewBag.Role == "Customer")">Khách hàng</option>
                <option value="Driver" selected="@((string?)ViewBag.Role == "Driver")">Tài xế</option>
            </select>
        </div>
        <div>
            <div class="field-label">Trạng thái</div>
            <select class="field-select" name="status">
                <option value="" selected="@(string.IsNullOrWhiteSpace((string?)ViewBag.Status))">Tất cả</option>
                <option value="active" selected="@((string?)ViewBag.Status == "active")">Hoạt động</option>
                <option value="locked" selected="@((string?)ViewBag.Status == "locked")">Tạm khóa</option>
            </select>
        </div>
        <div style="display:flex;align-items:flex-end;gap:8px;">
            <button class="btn btn-add" type="submit">Lọc</button>
            <a class="btn btn-back" href="/admin/users">Reset</a>
            <a class="btn btn-add" href="/admin/users/create">+ Thêm</a>
        </div>
    </form>
    <div style="display:grid;grid-template-columns:1fr 1fr auto;gap:12px;margin-top:10px;">
        <div>
            <div class="field-label">Vĩ độ phân vùng (tuỳ chọn)</div>
            <input class="field-input" type="number" step="0.000001" name="latitude" form="regionScopeForm" value="@ViewBag.Latitude" placeholder="VD: 21.0285 hoặc 10.7769" />
        </div>
        <div>
            <div class="field-label">Tỉnh/Thành (tuỳ chọn)</div>
            <input class="field-input" type="text" name="province" form="regionScopeForm" value="@ViewBag.Province" placeholder="VD: Ha Noi, Ho Chi Minh" />
        </div>
        <div style="display:flex;align-items:flex-end;">
            <button class="btn btn-add" type="submit" form="regionScopeForm">Đổi vùng dữ liệu</button>
        </div>
    </div>
    <form id="regionScopeForm" method="get" action="/admin/users">
        <input type="hidden" name="keyword" value="@ViewBag.Keyword" />
        <input type="hidden" name="role" value="@ViewBag.Role" />
        <input type="hidden" name="status" value="@ViewBag.Status" />
    </form>
    <div class="hint" style="margin-top:10px;">Đang xem dữ liệu: <b>@ViewBag.RegionScope</b></div>
</div>

<div class="panel" style="padding:12px;">
    <table class="users-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Họ và tên</th>
                <th>Email</th>
                <th>Role</th>
                <th>Khu vực</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var u in Model)
        {
            <tr>
                <td>@($"USR{u.UserId:D3}")</td>
                <td>@(string.IsNullOrWhiteSpace(u.Name) ? "-" : u.Name)</td>
                <td>@u.Email</td>
                <td>
                    <span class="pill @(u.Role == "Driver" ? "role-driver" : u.Role == "Customer" ? "role-customer" : "role-admin")">
                        @(u.Role == "Driver" ? "Tài xế" : u.Role == "Customer" ? "Khách hàng" : "Admin")
                    </span>
                </td>
                <td>
                    @(u.RegionId switch
                    {
                        1 => "Hà Nội",
                        2 => "TP. Hồ Chí Minh",
                        _ => "Đa vùng"
                    })
                </td>
                <td>
                    <span class="pill @(u.IsActive ? "status-active" : "status-locked")">
                        @(u.IsActive ? "Hoạt động" : "Tạm khóa")
                    </span>
                </td>
                <td>
                    <div class="actions">
                        <a class="btn btn-edit" href="/admin/users/edit/@u.UserId">✎</a>
                        <form asp-action="ToggleLock" asp-controller="AdminUsers" asp-route-id="@u.UserId" method="post" class="inline-form">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-lock" type="submit">@(u.IsActive ? "🔒" : "🔓")</button>
                        </form>
                        <form asp-action="Delete" asp-controller="AdminUsers" asp-route-id="@u.UserId" method="post" class="inline-form" onsubmit="return confirm('Xóa user này?');">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-del" type="submit">🗑</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
