@model RideAPI.Models.ViewModels.AdminDashboardViewModel
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment HostEnvironment
@{
    ViewData["Title"] = "Bảng điều khiển";
    ViewData["Nav"] = "dashboard";
    var regionText = Model.RegionId switch
    {
        "1" => "Miền Bắc",
        "2" => "Miền Nam",
        _ => string.IsNullOrWhiteSpace(Model.RegionId) ? "Toàn quốc" : Model.RegionId
    };
}

<div class="welcome-box panel">
    <h1 class="welcome-title">Chào mừng trở lại!</h1>
    <div class="welcome-sub">Quản lý hệ thống Ride Admin của bạn</div>
</div>

<div class="kpi-grid">
    <div class="kpi-card">
        <div class="kpi-icon">✉</div>
        <div>
            <div class="kpi-label">Email</div>
            <div class="kpi-value">@Model.Email</div>
        </div>
    </div>
    <div class="kpi-card">
        <div class="kpi-icon">🛡</div>
        <div>
            <div class="kpi-label">Vai trò</div>
            <div class="kpi-value">@Model.Role</div>
        </div>
    </div>
    <div class="kpi-card">
        <div class="kpi-icon" aria-hidden="true">▣</div>
        <div>
            <div class="kpi-label">Vùng</div>
            <div class="kpi-value">@regionText</div>
        </div>
    </div>
    <div class="kpi-card">
        <div class="kpi-icon">🕒</div>
        <div>
            <div class="kpi-label">Thời gian</div>
            <div class="kpi-value">08:30 - 17:30</div>
        </div>
    </div>
</div>

<h2 class="section-title">Thao tác nhanh</h2>
<div class="quick-grid">
    <a class="quick-card" href="/admin/users">
        <div class="quick-icon">👥</div>
        <h3 class="quick-title">Quản lý người dùng</h3>
        <div class="quick-desc">Xem và quản lý danh sách người dùng</div>
    </a>
    <a class="quick-card" href="/admin/trips">
        <div class="quick-icon">↭</div>
        <h3 class="quick-title">Chi tiết chuyến đi</h3>
        <div class="quick-desc">Tra cứu thông tin chuyến xe</div>
    </a>
    <a class="quick-card" href="/admin/nearby-drivers">
        <div class="quick-icon">🚕</div>
        <h3 class="quick-title">Tài xế lân cận</h3>
        <div class="quick-desc">Tìm tài xế theo vị trí</div>
    </a>
    @if (HostEnvironment.IsDevelopment())
    {
        <a class="quick-card" href="/swagger">
            <div class="quick-icon">📄</div>
            <h3 class="quick-title">Swagger API</h3>
            <div class="quick-desc">Tài liệu API và kiểm thử</div>
        </a>
    }
    else
    {
        <a class="quick-card" href="/admin/dashboard">
            <div class="quick-icon">🧩</div>
            <h3 class="quick-title">Trạng thái hệ thống</h3>
            <div class="quick-desc">Cập nhật lúc @Model.GeneratedAtUtc.ToString("HH:mm:ss") UTC</div>
        </a>
    }
</div>
