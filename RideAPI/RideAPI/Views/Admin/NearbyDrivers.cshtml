@{
    ViewData["Title"] = "Tài xế gần đây";
    ViewData["Nav"] = "nearby";
}

<h1 class="panel-title">Tài xế lân cận</h1>
<div class="toolbar" style="margin-top:-6px;">
    <div></div>
    <a class="btn-dark" href="/admin/dashboard">← Bảng điều khiển</a>
</div>

<div class="panel tool-form" style="margin-bottom:14px;">
    <h2 style="margin:0 0 14px;">Bộ lọc vị trí</h2>
    <div class="tool-row nearby">
        <div>
            <div class="field-label">Vĩ độ (Latitude)</div>
            <input class="field-input" id="latitude" type="number" step="0.000001" value="10.8" placeholder="21.0285" />
        </div>
        <div>
            <div class="field-label">Kinh độ (Longitude)</div>
            <input class="field-input" id="longitude" type="number" step="0.000001" value="106.6" placeholder="105.8542" />
        </div>
        <div>
            <div class="field-label">Bán kính (km)</div>
            <input class="field-input" id="radiusKm" type="number" step="0.1" value="10" placeholder="5" />
        </div>
        <div>
            <div class="field-label">Số lượng</div>
            <input class="field-input" id="limit" type="number" min="1" value="20" placeholder="20" />
        </div>
    </div>
    <div style="margin-top:12px;">
        <div class="field-label">X-User-Latitude fallback</div>
        <input class="field-input" id="lat" type="number" step="0.000001" value="10.8" placeholder="10.8" />
    </div>
    <div class="tool-actions">
        <button id="btnLoad" type="button" class="tool-btn">🔎 Tìm tài xế</button>
    </div>
</div>

<div class="panel tool-form">
    <h2 style="margin:0 0 12px;">Danh sách tài xế <span id="countBadge" class="pill status-active" style="margin-left:8px;display:none;"></span></h2>
    <div id="status" class="status-line">Trạng thái: Chưa tải dữ liệu.</div>
    <table id="driverTable" class="data-table compact" style="display:none;">
        <thead>
            <tr>
                <th>ID</th>
                <th>Tên tài xế</th>
                <th>Số điện thoại</th>
                <th>Trạng thái</th>
                <th>Tọa độ</th>
                <th>Khoảng cách</th>
            </tr>
        </thead>
        <tbody id="driverTbody"></tbody>
    </table>
    <div id="empty" class="empty-note">Chưa có dữ liệu.</div>
</div>

@section Scripts {
<script>
    const btn = document.getElementById('btnLoad');
    const statusEl = document.getElementById('status');
    const driverTable = document.getElementById('driverTable');
    const driverTbody = document.getElementById('driverTbody');
    const emptyEl = document.getElementById('empty');
    const countBadge = document.getElementById('countBadge');

    function setLoading() {
        statusEl.textContent = 'Trạng thái: Đang tải...';
        driverTable.style.display = 'none';
        emptyEl.style.display = 'block';
        emptyEl.textContent = 'Đang tải dữ liệu...';
        countBadge.style.display = 'none';
    }

    function statusBadge(statusRaw) {
        const val = (statusRaw ?? '').toString().toLowerCase();
        if (val.includes('available') || val.includes('san') || val.includes('rảnh') || val.includes('ready'))
            return '<span class="pill status-active">Sẵn sàng</span>';
        if (val.includes('busy') || val.includes('run'))
            return '<span class="pill status-locked">Đang chạy</span>';
        return `<span class="pill role-admin">${statusRaw ?? '-'}</span>`;
    }

    function renderDrivers(rows) {
        driverTbody.innerHTML = '';
        rows.forEach(x => {
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td>DRV${String(x.driverId ?? '').padStart(3, '0')}</td>
                <td>${x.name ?? ''}</td>
                <td>${x.phone ?? ''}</td>
                <td>${statusBadge(x.status)}</td>
                <td>${(x.latitude ?? '').toString()} / ${(x.longitude ?? '').toString()}</td>
                <td>${x.distanceKm ?? ''} km</td>`;
            driverTbody.appendChild(tr);
        });
        driverTable.style.display = 'table';
        emptyEl.style.display = 'none';
        countBadge.textContent = `Tìm thấy ${rows.length} tài xế`;
        countBadge.style.display = 'inline-flex';
    }

    btn.addEventListener('click', async () => {
        const latitude = document.getElementById('latitude').value;
        const longitude = document.getElementById('longitude').value;
        const radiusKm = document.getElementById('radiusKm').value;
        const limit = document.getElementById('limit').value;
        const lat = document.getElementById('lat').value;

        const url = `/api/drivers/nearby?latitude=${encodeURIComponent(latitude)}&longitude=${encodeURIComponent(longitude)}&radiusKm=${encodeURIComponent(radiusKm)}&limit=${encodeURIComponent(limit)}&lat=${encodeURIComponent(lat)}`;
        setLoading();

        try {
            const res = await fetch(url, { method: 'GET', credentials: 'same-origin' });
            const text = await res.text();
            statusEl.textContent = `Trạng thái: ${res.status}`;

            if (!res.ok) {
                emptyEl.style.display = 'block';
                emptyEl.textContent = 'Không tải được dữ liệu.';
                return;
            }

            let data;
            try {
                data = JSON.parse(text);
            } catch {
                data = null;
            }

            if (!Array.isArray(data) || data.length === 0) {
                driverTable.style.display = 'none';
                emptyEl.style.display = 'block';
                emptyEl.textContent = 'Không có tài xế phù hợp.';
                return;
            }

            renderDrivers(data);
        } catch (e) {
            statusEl.textContent = 'Trạng thái: Lỗi';
            emptyEl.style.display = 'block';
            emptyEl.textContent = `Lỗi: ${e}`;
        }
    });
</script>
}
