@{
    ViewData["Title"] = "Nearby Drivers";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        body { font-family: Arial, Helvetica, sans-serif; margin: 0; background: #f4f6fb; color: #1f2937; }
        .container { max-width: 980px; margin: 24px auto; padding: 0 16px; }
        .card { background:#fff; border-radius:12px; padding:16px; box-shadow:0 2px 8px rgba(0,0,0,.06); }
        .row { display:grid; grid-template-columns: repeat(5, 1fr) auto; gap:10px; margin-bottom:12px; }
        input { width:100%; padding:10px; border:1px solid #d1d5db; border-radius:8px; box-sizing:border-box; }
        button, a { border:0; background:#2563eb; color:#fff; padding:10px 14px; border-radius:8px; cursor:pointer; text-decoration:none; display:inline-block; }
        .back { background:#6b7280; }
        .hint { background:#eef2ff; border:1px solid #c7d2fe; color:#3730a3; border-radius:8px; padding:10px; margin-bottom:12px; font-size:14px; }
        .status { margin-bottom:12px; font-size:14px; color:#374151; }
        table { width:100%; border-collapse: collapse; background:#fff; }
        th, td { border:1px solid #e5e7eb; padding:10px; text-align:left; font-size:14px; }
        th { background:#f9fafb; }
        .empty { color:#6b7280; font-style:italic; }
        pre { background:#111827; color:#e5e7eb; border-radius:8px; padding:12px; overflow:auto; min-height:100px; margin-top:12px; }
    </style>
</head>
<body>
    <div class="container">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
            <h1 style="margin:0;">Nearby Drivers</h1>
            <a class="back" href="/admin/dashboard">Quay lại Dashboard</a>
        </div>

        <div class="card">
            <div class="hint">
                Tải dữ liệu: nhập vị trí + bán kính + số lượng bản ghi. Nút <b>Tải dữ liệu</b> sẽ lấy danh sách tài xế gần nhất và hiển thị theo bảng.
            </div>

            <div class="row">
                <input id="latitude" type="number" step="0.000001" value="10.8" placeholder="latitude" />
                <input id="longitude" type="number" step="0.000001" value="106.6" placeholder="longitude" />
                <input id="radiusKm" type="number" step="0.1" value="10" placeholder="radiusKm" />
                <input id="limit" type="number" min="1" value="20" placeholder="limit" />
                <input id="lat" type="number" step="0.000001" value="10.8" placeholder="lat (middleware)" />
                <button id="btnLoad" type="button">Tải dữ liệu</button>
            </div>

            <div id="status" class="status">Trạng thái: Chưa tải dữ liệu.</div>
            <table id="driverTable" style="display:none;">
                <thead>
                    <tr>
                        <th>DriverId</th>
                        <th>Tên</th>
                        <th>SĐT</th>
                        <th>Trạng thái</th>
                        <th>Latitude</th>
                        <th>Longitude</th>
                        <th>DistanceKm</th>
                    </tr>
                </thead>
                <tbody id="driverTbody"></tbody>
            </table>
            <div id="empty" class="empty">Chưa có dữ liệu.</div>
            <pre id="resultRaw" style="display:none;"></pre>
        </div>
    </div>

    <script>
        const btn = document.getElementById('btnLoad');
        const statusEl = document.getElementById('status');
        const driverTable = document.getElementById('driverTable');
        const driverTbody = document.getElementById('driverTbody');
        const emptyEl = document.getElementById('empty');
        const resultRaw = document.getElementById('resultRaw');

        function setLoading() {
            statusEl.textContent = 'Trạng thái: Đang tải...';
            driverTable.style.display = 'none';
            emptyEl.style.display = 'block';
            emptyEl.textContent = 'Đang tải dữ liệu...';
            resultRaw.style.display = 'none';
        }

        function renderDrivers(rows) {
            driverTbody.innerHTML = '';
            rows.forEach(x => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td>${x.driverId ?? ''}</td>
                    <td>${x.name ?? ''}</td>
                    <td>${x.phone ?? ''}</td>
                    <td>${x.status ?? ''}</td>
                    <td>${x.latitude ?? ''}</td>
                    <td>${x.longitude ?? ''}</td>
                    <td>${x.distanceKm ?? ''}</td>`;
                driverTbody.appendChild(tr);
            });
            driverTable.style.display = 'table';
            emptyEl.style.display = 'none';
        }

        btn.addEventListener('click', async () => {
            const latitude = document.getElementById('latitude').value;
            const longitude = document.getElementById('longitude').value;
            const radiusKm = document.getElementById('radiusKm').value;
            const limit = document.getElementById('limit').value;
            const lat = document.getElementById('lat').value;

            const url = `/api/drivers/nearby?latitude=${encodeURIComponent(latitude)}&longitude=${encodeURIComponent(longitude)}&radiusKm=${encodeURIComponent(radiusKm)}&limit=${encodeURIComponent(limit)}&lat=${encodeURIComponent(lat)}`;
            setLoading();

            try {
                const res = await fetch(url, { method: 'GET' });
                const text = await res.text();
                statusEl.textContent = `Trạng thái: ${res.status}`;

                if (!res.ok) {
                    emptyEl.style.display = 'block';
                    emptyEl.textContent = 'Không tải được dữ liệu.';
                    resultRaw.style.display = 'block';
                    resultRaw.textContent = text;
                    return;
                }

                let data;
                try {
                    data = JSON.parse(text);
                } catch {
                    data = null;
                }

                if (!Array.isArray(data) || data.length === 0) {
                    driverTable.style.display = 'none';
                    emptyEl.style.display = 'block';
                    emptyEl.textContent = 'Không có tài xế phù hợp.';
                    resultRaw.style.display = 'block';
                    resultRaw.textContent = text;
                    return;
                }

                renderDrivers(data);
                resultRaw.style.display = 'block';
                resultRaw.textContent = JSON.stringify(data, null, 2);
            } catch (e) {
                statusEl.textContent = 'Trạng thái: Lỗi';
                emptyEl.style.display = 'block';
                emptyEl.textContent = `Lỗi: ${e}`;
            }
        });
    </script>
</body>
</html>
