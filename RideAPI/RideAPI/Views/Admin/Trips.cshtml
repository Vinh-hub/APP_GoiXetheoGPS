@{
    ViewData["Title"] = "Chuyến (Trip)";
    ViewData["Nav"] = "trips";
    var defaultLatitude = !string.IsNullOrWhiteSpace(ViewBag.ScopeLatitude as string)
        ? (string)ViewBag.ScopeLatitude
        : ((int?)ViewBag.ScopeRegionId == 1 ? "21.0285" : "10.7769");
}

<div class="toolbar">
    <h1 class="panel-title" style="margin:0;">Chi tiết chuyến</h1>
    <a class="btn-dark" href="/admin/dashboard">← Bảng điều khiển</a>
</div>

<div class="panel tool-form" style="margin-bottom:14px;">
    <h2 style="margin:0 0 14px;">Tra cứu chuyến đi</h2>
    <div class="tool-row trips">
        <div>
            <div class="field-label">Mã chuyến đi</div>
            <input class="field-input" id="tripId" type="number" min="1" value="1" placeholder="TRIP20240428001" />
        </div>
        <div>
            <div class="field-label">Vĩ độ (Latitude)</div>
            <input class="field-input" id="latitude" type="number" step="0.000001" value="@defaultLatitude" placeholder="10.8" />
        </div>
        <div>
            <div class="field-label">Kinh độ fallback (Middleware)</div>
            <input class="field-input" id="lat" type="number" step="0.000001" value="@defaultLatitude" placeholder="10.8" />
        </div>
    </div>
    <div class="tool-actions">
        <button id="btnLoad" type="button" class="tool-btn">🔍 Tìm kiếm chuyến đi</button>
    </div>
</div>

<div class="panel tool-form">
    <h2 style="margin:0 0 10px;">Thông tin chuyến đi</h2>
    <div id="status" class="status-line">Trạng thái: Chưa tải dữ liệu.</div>
    <div id="tripDetail" class="trip-detail-grid" style="display:none;"></div>
    <div id="empty" class="empty-note">Chưa có dữ liệu.</div>
</div>

<template id="tripRowTemplate">
    <div class="trip-item">
        <div class="trip-item-key"></div>
        <div class="trip-item-val"></div>
    </div>
</template>

@section Scripts {
<script>
    const btn = document.getElementById('btnLoad');
    const statusEl = document.getElementById('status');
    const tripDetail = document.getElementById('tripDetail');
    const emptyEl = document.getElementById('empty');
    const rowTemplate = document.getElementById('tripRowTemplate');

    function setLoading() {
        statusEl.textContent = 'Trạng thái: Đang tải...';
        tripDetail.style.display = 'none';
        emptyEl.style.display = 'block';
        emptyEl.textContent = 'Đang tải dữ liệu...';
    }

    function displayValue(v) {
        if (v === null || v === undefined || v === '') return '-';
        if (typeof v === 'number') return Number.isInteger(v) ? String(v) : v.toFixed(6);
        return String(v);
    }

    function pickValue(data, ...keys) {
        for (const key of keys) {
            if (Object.prototype.hasOwnProperty.call(data, key)) {
                return data[key];
            }
        }
        return null;
    }

    function renderTripDetails(data) {
        const keyMap = [
            [['tripId', 'tripID', 'TripId', 'TripID'], 'Mã chuyến'],
            [['status', 'Status'], 'Trạng thái'],
            [['userId', 'userID', 'UserId', 'UserID'], 'Khách hàng (UserId)'],
            [['driverId', 'driverID', 'DriverId', 'DriverID'], 'Tài xế (DriverId)'],
            [['price', 'Price'], 'Cước phí'],
            [['paymentAmount', 'PaymentAmount'], 'Thanh toán'],
            [['startLat', 'startLAT', 'StartLat', 'StartLAT'], 'Điểm đón - Vĩ độ'],
            [['startLng', 'startLNG', 'StartLng', 'StartLNG'], 'Điểm đón - Kinh độ'],
            [['endLat', 'endLAT', 'EndLat', 'EndLAT'], 'Điểm đến - Vĩ độ'],
            [['endLng', 'endLNG', 'EndLng', 'EndLNG'], 'Điểm đến - Kinh độ'],
            [['driverRating', 'DriverRating'], 'Đánh giá tài xế'],
            [['driverComment', 'DriverComment'], 'Nhận xét'],
            [['createdAt', 'CreatedAt'], 'Thời gian tạo']
        ];

        tripDetail.innerHTML = '';
        keyMap.forEach(([keys, label]) => {
            const frag = rowTemplate.content.cloneNode(true);
            frag.querySelector('.trip-item-key').textContent = label;
            frag.querySelector('.trip-item-val').textContent = displayValue(pickValue(data, ...keys));
            tripDetail.appendChild(frag);
        });

        tripDetail.style.display = 'grid';
        emptyEl.style.display = 'none';
    }

    btn.addEventListener('click', async () => {
        const tripId = document.getElementById('tripId').value;
        const latitude = document.getElementById('latitude').value;
        const lat = document.getElementById('lat').value;

        const url = `/api/trips/${encodeURIComponent(tripId)}?latitude=${encodeURIComponent(latitude)}&lat=${encodeURIComponent(lat)}`;
        setLoading();

        try {
            const res = await fetch(url, { method: 'GET', credentials: 'same-origin' });
            const text = await res.text();
            statusEl.textContent = `Trạng thái: ${res.status}`;

            if (!res.ok) {
                emptyEl.style.display = 'block';
                emptyEl.textContent = 'Không tải được dữ liệu.';
                return;
            }

            let data;
            try {
                data = JSON.parse(text);
            } catch {
                data = null;
            }

            if (!data || typeof data !== 'object' || Array.isArray(data)) {
                emptyEl.style.display = 'block';
                emptyEl.textContent = 'Dữ liệu không đúng định dạng JSON object.';
                return;
            }

            renderTripDetails(data);
        } catch (e) {
            statusEl.textContent = 'Trạng thái: Lỗi';
            emptyEl.style.display = 'block';
            emptyEl.textContent = `Lỗi: ${e}`;
        }
    });
</script>
}
